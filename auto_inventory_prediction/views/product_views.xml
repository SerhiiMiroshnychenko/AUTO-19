<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="product_template_form_view_auto_prediction">
            <field name="name">product.template.form.view.auto.prediction</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="stock.product_template_form_view_procurement_button" />
            <field name="priority" eval="15" />
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//span[@invisible='virtual_available != 0']" position="replace">
                        <span class="o_stat_value" invisible="virtual_available_real != 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>
                    <xpath expr="//span[@invisible='virtual_available &lt;= 0']" position="replace">
                        <span class="o_stat_value text-info" invisible="virtual_available_real &lt;= 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>
                    <xpath expr="//span[@invisible='virtual_available &gt;= 0']" position="replace">
                        <span class="o_stat_value text-danger" invisible="virtual_available_real &gt;= 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>

                    <!-- Add legacy name mapping after barcode -->
                    <xpath expr="//field[@name='barcode']" position="after">
                        <field name="old_name" help="Назва продукту в старій базі для точного мапінгу з CSV історичними даними"/>
                    </xpath>
                </data>
            </field>
        </record>

        <record model="ir.ui.view" id="product_form_view_auto_prediction">
            <field name="name">product.product.form.view.auto.prediction</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock.product_form_view_procurement_button" />
            <field name="priority" eval="15" />
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//span[@invisible='virtual_available != 0']" position="replace">
                        <span class="o_stat_value" invisible="virtual_available_real != 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>
                    <xpath expr="//span[@invisible='virtual_available &lt;= 0']" position="replace">
                        <span class="o_stat_value text-info" invisible="virtual_available_real &lt;= 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>
                    <xpath expr="//span[@invisible='virtual_available &gt;= 0']" position="replace">
                        <span class="o_stat_value text-danger" invisible="virtual_available_real &gt;= 0">
                            <field name="virtual_available_real" nolabel="1"/>
                        </span>
                    </xpath>

                    <!-- Add legacy name mapping after barcode -->
                    <xpath expr="//field[@name='barcode']" position="after">
                        <field name="old_name" help="Назва продукту в старій базі для точного мапінгу з CSV історичними даними"/>
                    </xpath>
                </data>
            </field>
        </record>

        <!-- Kanban view extension for product template -->
        <record model="ir.ui.view" id="product_template_kanban_view_auto_prediction">
            <field name="name">product.template.kanban.view.auto.prediction</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="stock.product_template_kanban_stock_view" />
            <field name="arch" type="xml">
                <xpath expr="//kanban" position="inside">
                    <field name="unconfirmed_outgoing_qty"/>
                </xpath>
                <xpath expr="//field[@name='product_properties']" position="after">
                    <div t-if="record.unconfirmed_outgoing_qty.raw_value" class="text-muted">
                        <small>Unconfirmed: <field name="unconfirmed_outgoing_qty"/></small>
                    </div>
                </xpath>
            </field>
        </record>

        <!-- List view extension for product.product -->
        <record model="ir.ui.view" id="product_product_list_view_auto_prediction">
            <field name="name">product.product.list.view.auto.prediction</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock.view_stock_product_tree" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='virtual_available']" position="after">
                    <field name="unconfirmed_outgoing_qty" string="Unconfirmed Out" optional="hide"/>
                    <field name="virtual_available_ml" string="Virtual ML" optional="show"/>
                    <field name="virtual_available_real" string="Forecasted ML" optional="hide"/>
                    <field name="incoming_onhand_qty" string="Inc. On-Hand" optional="hide"/>
                    <field name="incoming_inbound_qty" string="Inc. Inbound" optional="hide"/>
                    <field name="incoming_missing_qty" string="Missing Components" optional="hide"/>
                    <field name="virtual_onhand_qty" string="Virtual On-Hand" optional="hide"/>
                    <field name="old_name" string="Назва в старій базі" optional="hide"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
