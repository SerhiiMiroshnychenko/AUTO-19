<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Manufacturing Order Form View Extension -->
    <record id="view_mrp_production_form_creation_info" model="ir.ui.view">
        <field name="name">mrp.production.form.creation.info</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div style="position: absolute; top: 10px; right: 20px; z-index: 1000;"
                     invisible="not creation_information">
                    <field name="creation_information" nolabel="1" readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
