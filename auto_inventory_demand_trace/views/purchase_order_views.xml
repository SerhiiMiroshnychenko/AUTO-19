<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Order Form View Extension -->
    <record id="view_purchase_order_form_creation_info" model="ir.ui.view">
        <field name="name">purchase.order.form.creation.info</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div style="position: absolute; top: 0px; right: 5px; z-index: 1000;"
                     invisible="not creation_information">
                    <field name="creation_information" nolabel="1" readonly="1"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
