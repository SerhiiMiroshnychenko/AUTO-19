<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="stock.ForecastedDetails" t-inherit-mode="extension">
        <!-- Вставка "Incoming number of products" перед Forecasted Inventory -->
        <xpath expr="//tr[contains(@class, 'o_forecasted_row') and td[text()='Forecasted Inventory']]" position="before">
            <tr class="o_forecasted_row table-secondary fw-bold">
                <td/>
                <td>Incoming number of products</td>
                <td class="text-end">
                    <t t-out="_formatFloat(this.props.docs.incoming_qty)"/>
                </td>
                <td colspan="3"/>
            </tr>
        </xpath>

        <!-- Вставка Draft Sale Orders (ML Predictions) після Forecasted Inventory -->
        <xpath expr="//tr[contains(@class, 'o_forecasted_row') and td[text()='Forecasted Inventory']]" position="after">
            <t t-foreach="props.docs.draft_sale_orders" t-as="sale_order" t-key="sale_order_index">
                <tr name="ml_draft_so_out">
                    <td/>
                    <td>
                        <a t-attf-href="#" t-out="sale_order.name"
                            class="fw-bold"
                            t-on-click.prevent="() => this.props.openView('sale.order', 'form', sale_order.id)"/>
                    </td>
                    <td t-out="_formatFloat(-sale_order.final_value)" class="text-end"/>
                    <td colspan="3"> 
                        <t t-out="_formatFloat(-sale_order.original_value)"/> 
                        x <t t-out="sale_order.ml_probability"/> 
                        = <t t-out="_formatFloat(-sale_order.modified_value)"/>
                        <t t-if="sale_order.no_delivery_batches"> 
                            / <t t-out="sale_order.no_delivery_batches"/> Batches 
                            = <t t-out="_formatFloat(-sale_order.final_value)"/> 
                        </t>
                        <t t-if="sale_order.direct_value or sale_order.indirect_value">
                            |
                            Direct: <t t-out="_formatFloat(-(sale_order.direct_value or 0.0))"/>
                            +
                            Indirect(BOM): <t t-out="_formatFloat(-(sale_order.indirect_value or 0.0))"/>
                        </t>
                    </td>
                </tr>
            </t>
        </xpath>
    </t>
</templates>
